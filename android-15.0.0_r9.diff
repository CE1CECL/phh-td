diff -prNu android-15.0.0_r9/system/sepolicy/prebuilts/api/28.0/private/untrusted_app.te android-15.0.0_r9-td/system/sepolicy/prebuilts/api/28.0/private/untrusted_app.te
--- android-15.0.0_r9/system/sepolicy/prebuilts/api/28.0/private/untrusted_app.te	1969-12-31 19:00:00.000000000 -0500
+++ android-15.0.0_r9-td/system/sepolicy/prebuilts/api/28.0/private/untrusted_app.te	2026-07-09 12:16:57.632873865 -0400
@@ -0,0 +1,25 @@
+###
+### Untrusted apps.
+###
+### This file defines the rules for untrusted apps.
+### Apps are labeled based on mac_permissions.xml (maps signer and
+### optionally package name to seinfo value) and seapp_contexts (maps UID
+### and optionally seinfo value to domain for process and type for data
+### directory).  The untrusted_app domain is the default assignment in
+### seapp_contexts for any app with UID between APP_AID (10000)
+### and AID_ISOLATED_START (99000) if the app has no specific seinfo
+### value as determined from mac_permissions.xml.  In current AOSP, this
+### domain is assigned to all non-system apps as well as to any system apps
+### that are not signed by the platform key.  To move
+### a system app into a specific domain, add a signer entry for it to
+### mac_permissions.xml and assign it one of the pre-existing seinfo values
+### or define and use a new seinfo value in both mac_permissions.xml and
+### seapp_contexts.
+###
+
