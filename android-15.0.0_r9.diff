diff -prNu android-15.0.0_r9/system/sepolicy/prebuilts/api/28.0/private/uncrypt.te android-15.0.0_r9-td/system/sepolicy/prebuilts/api/28.0/private/uncrypt.te
--- android-15.0.0_r9/system/sepolicy/prebuilts/api/28.0/private/uncrypt.te	1969-12-31 19:00:00.000000000 -0500
+++ android-15.0.0_r9-td/system/sepolicy/prebuilts/api/28.0/private/uncrypt.te	2026-07-09 12:16:57.632873865 -0400
