diff -prNu android-15.0.0_r9/system/sepolicy/prebuilts/api/28.0/public/hwservicemanager.te android-15.0.0_r9-td/system/sepolicy/prebuilts/api/28.0/public/hwservicemanager.te
--- android-15.0.0_r9/system/sepolicy/prebuilts/api/28.0/public/hwservicemanager.te	1969-12-31 19:00:00.000000000 -0500
+++ android-15.0.0_r9-td/system/sepolicy/prebuilts/api/28.0/public/hwservicemanager.te	2026-07-09 12:16:57.652873926 -0400
@@ -0,0 +1,22 @@
+# hwservicemanager - the Binder context manager for HAL services
+type hwservicemanager, domain, mlstrustedsubject;
+type hwservicemanager_exec, exec_type, file_type;
+
+# Note that we do not use the binder_* macros here.
+# hwservicemanager provides name service (aka context manager)
+# for hwbinder.
+# Additionally, it initiates binder IPC calls to
+# clients who request service notifications. The permission
+# to do this is granted in the hwbinder_use macro.
+allow hwservicemanager self:binder set_context_mgr;
+
+set_prop(hwservicemanager, hwservicemanager_prop)
+
+# Scan through /system/lib64/hw looking for installed HALs
+allow hwservicemanager system_file:dir r_dir_perms;
+
+# Read hwservice_contexts
+allow hwservicemanager hwservice_contexts_file:file r_file_perms;
+
+# Check SELinux permissions.
+selinux_check_access(hwservicemanager)
diff -prNu android-15.0.0_r9/system/sepolicy/prebuilts/api/28.0/public/idmap.te android-15.0.0_r9-td/system/sepolicy/prebuilts/api/28.0/public/idmap.te
