+
+typeattribute vold_prepare_subdirs coredomain;
diff -prNu android-15.0.0_r9/system/sepolicy/prebuilts/api/28.0/public/vr_hwc.te android-15.0.0_r9-td/system/sepolicy/prebuilts/api/28.0/public/vr_hwc.te
